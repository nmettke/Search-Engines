#!/bin/bash

set -e

echo "Checking formatting..."
files=$(find src test \( -name '*.cpp' -o -name '*.cc' -o -name '*.hpp' -o -name '*.h' \))
if [ -n "$files" ]; then
    clang-format --dry-run --Werror $files
fi

echo "Building project..."
cmake --build build

echo "Running tests..."
cd build || exit 1
ctest --output-on-failure

if [ $? -ne 0 ]; then
    echo "Tests failed. Fix before committing."
    exit 1
fi

echo "Tests passed!"